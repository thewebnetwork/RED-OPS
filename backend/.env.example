# MongoDB connection
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=red_ribbon_ops

# JWT authentication
JWT_SECRET=your-super-secret-key-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin seed account (used by ensure_admin_account on startup)
ADMIN_EMAIL=redops@redribbongroup.ca
ADMIN_PASSWORD=change-me-in-production

# CORS — comma-separated origins, no brackets or quotes
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# Optional: iframe embedding
ALLOW_IFRAME_EMBEDDING=true
FRAME_ANCESTORS=*
